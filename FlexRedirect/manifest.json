{
  "manifest_version": 3,
  "name": "Flex Redirect",
  "version": "1.2.3",
  "description": "Start page redirector",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "redirect.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Settings"
  },
  "icons": {
    "128": "icon.png"
  }
}
